  }
  .v10a-bio p {
    font-size: 15px; line-height: 1.7; color: rgba(255,255,255,0.5); margin-bottom: 24px;
  }
  .v10a-bio .links { display: flex; gap: 12px; }
  .v10a-bio .links a {
    font-size: 13px; text-decoration: none; padding: 10px 24px; border-radius: 100px;
    border: 2px solid #e8a838; color: #e8a838; font-weight: 600;
    transition: all 0.2s;
  }
  .v10a-bio .links a:hover { background: #e8a838; color: #fff; }

  /* --- 10B: Jasny bento, minimalne kolory --- */
  .v10b-wrap {
    display: grid; grid-template-columns: 1fr 2fr; gap: 16px;
  }
  .v10b-wrap.reverse { grid-template-columns: 2fr 1fr; }
  .v10b-photo {
    border-radius: 20px; overflow: hidden; min-height: 340px;
  }
  .v10b-photo img { width: 100%; height: 100%; object-fit: cover; }
  .v10b-bio {
    background: #fff; border-radius: 20px; padding: 48px;
    display: flex; flex-direction: column; justify-content: center;
    border: 1px solid #eee;
  }
  .v10b-bio h3 {
    font-size: 28px; font-weight: 700; color: #1a1a1a; margin-bottom: 4px;
  }
  .v10b-bio .role {
    font-size: 12px; text-transform: uppercase; letter-spacing: 2px;
    color: #ccc; margin-bottom: 20px; font-weight: 500;
  }
  .v10b-bio p {
    font-size: 14px; line-height: 1.7; color: #888; margin-bottom: 24px;
  }
  .v10b-bio .links a {
    font-size: 13px; text-decoration: none; color: #1a1a1a; margin-right: 20px;
    font-weight: 600; border-bottom: 2px solid #e8a838; padding-bottom: 2px;
  }

  /* --- 10C: Gradient bento, duży headline --- */
  .v10c-wrap {
    display: grid; grid-template-columns: 1fr 2fr; gap: 16px;
  }
  .v10c-wrap.reverse { grid-template-columns: 2fr 1fr; }
  .v10c-photo {
    border-radius: 24px; overflow: hidden; min-height: 380px;
  }
  .v10c-photo img { width: 100%; height: 100%; object-fit: cover; }
  .v10c-bio {
    background: linear-gradient(135deg, #1a1510 0%, #2a2118 100%);
    border-radius: 24px; padding: 56px;
    display: flex; flex-direction: column; justify-content: center;
    position: relative; overflow: hidden;
  }
  .v10c-bio::after {
    content: ''; position: absolute; top: -100px; right: -100px;
    width: 300px; height: 300px; border-radius: 50%;
    background: rgba(232,168,56,0.06);
  }
  .v10c-bio h3 {
    font-size: 40px; font-weight: 900; color: #fff; margin-bottom: 6px;
    letter-spacing: -1px; line-height: 1.1; position: relative;
  }
  .v10c-bio .role {
    font-size: 13px; font-weight: 500; color: #e8a838; margin-bottom: 20px;
    position: relative;
  }
  .v10c-bio p {
    font-size: 15px; line-height: 1.7; color: rgba(255,255,255,0.45); margin-bottom: 28px;
    position: relative;
  }
  .v10c-bio .links { display: flex; gap: 12px; position: relative; }
  .v10c-bio .links a {
    font-size: 13px; text-decoration: none; padding: 10px 28px; border-radius: 100px;
    background: rgba(232,168,56,0.15); color: #e8a838; font-weight: 600;
    transition: all 0.2s; border: 1px solid rgba(232,168,56,0.3);
  }
  .v10c-bio .links a:hover { background: #e8a838; color: #fff; }

  /* --- 10D: Bento z numerami porządkowymi --- */
  .v10d-wrap {
    display: grid; grid-template-columns: 1fr 2fr; gap: 16px;
  }
  .v10d-wrap.reverse { grid-template-columns: 2fr 1fr; }
  .v10d-photo {
    border-radius: 20px; overflow: hidden; min-height: 360px;
    position: relative;
  }
  .v10d-photo img { width: 100%; height: 100%; object-fit: cover; }
  .v10d-photo .num {
    position: absolute; top: 20px; left: 20px;
    font-size: 80px; font-weight: 900; color: rgba(255,255,255,0.15);
    line-height: 1;
  }
  .v10d-bio {
    background: #f0ebe4; border-radius: 20px; padding: 48px;
    display: flex; flex-direction: column; justify-content: center;
  }
  .v10d-bio h3 {
    font-size: 30px; font-weight: 800; color: #1a1a1a; margin-bottom: 8px;
    letter-spacing: -0.5px;
  }
  .v10d-bio .role {
    font-size: 12px; text-transform: uppercase; letter-spacing: 2.5px;
    color: #c89530; margin-bottom: 20px; font-weight: 600;
  }
  .v10d-bio p {
    font-size: 14px; line-height: 1.7; color: #888; margin-bottom: 24px;
  }
  .v10d-bio .links a {
    font-size: 13px; text-decoration: none; color: #1a1a1a; margin-right: 20px;
    font-weight: 600; padding: 8px 20px; border-radius: 100px;
    background: #fff; transition: all 0.2s;
  }
  .v10d-bio .links a:hover { background: #e8a838; color: #fff; }

  /* --- 10E: Full dark, zdjęcie duże, bio wąskie --- */
  .v10e-wrap {
    display: grid; grid-template-columns: 3fr 2fr; gap: 16px;
  }
  .v10e-wrap.reverse { grid-template-columns: 2fr 3fr; }
  .v10e-photo {
    border-radius: 20px; overflow: hidden; min-height: 420px;
  }
  .v10e-photo img { width: 100%; height: 100%; object-fit: cover; }
  .v10e-bio {
    background: #0f0c08; border-radius: 20px; padding: 44px;
    display: flex; flex-direction: column; justify-content: center;
    border: 1px solid rgba(255,255,255,0.06);
  }
  .v10e-bio h3 {
    font-size: 24px; font-weight: 700; color: #fff; margin-bottom: 4px;
  }
  .v10e-bio .role {
    font-size: 11px; text-transform: uppercase; letter-spacing: 3px;
    color: #e8a838; margin-bottom: 20px; font-weight: 500;
  }
  .v10e-bio p {
    font-size: 14px; line-height: 1.7; color: rgba(255,255,255,0.4); margin-bottom: 28px;
  }
  .v10e-bio .links { display: flex; flex-direction: column; gap: 8px; }
  .v10e-bio .links a {
    font-size: 13px; text-decoration: none; padding: 10px 20px; border-radius: 12px;
    background: rgba(232,168,56,0.1); color: #e8a838; font-weight: 600;
    text-align: center; transition: all 0.2s;
  }
  .v10e-bio .links a:hover { background: #e8a838; color: #fff; }
</style>
