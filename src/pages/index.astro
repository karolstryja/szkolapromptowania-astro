  <style>
    /* scroll-margin for anchor links under sticky navbar */
    .section, .blog-scroll-section, .page-wrapper {
      scroll-margin-top: 90px;
    }

    /* Override Webflow .page-wrapper overflow:hidden — clip preserves
       visual clipping but doesn't break position:sticky */
    .page-wrapper {
      overflow: clip;
    }

    /* Force disc bullets instead of squares */
    .list, .blog-list, .banner-list-flex {
      list-style-type: disc !important;
    }

    /* Navbar — sticky top, always visible */
    .navbar {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }

    /* Navbar logo override */
    .navbar-brand .image {
      max-width: none;
      max-height: none;
      height: 44px;
      width: auto;
    }
    .navbar-brand.w--current {
      align-self: center !important;
    }
    .navber-menu-wrap {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    /* CTA button — filled amber, cohesive with logo */
    .primary-btn-wrap {
      background-color: var(--primary) !important;
      border-color: var(--primary) !important;
    }
    .primary-btn-wrap .button-text {
      color: #09080e !important;
      text-transform: none !important;
    }
    .primary-btn-wrap .arrow-01 {
      filter: brightness(0) !important;
    }
    /* Hero h1 — tighter tracking */
    .banner-content h1 {
      letter-spacing: -7px;
    }
    .primary-btn-wrap:hover {
      background-color: var(--primary-tint) !important;
      border-color: var(--primary-tint) !important;
    }
    /* Footer decorative watermark — mimics original Slayed positioning */
    .footer-inner-wrap {
      overflow: hidden !important;
    }
    .footer-watermark {
      position: absolute;
      bottom: -30px;
      right: -10px;
      font-family: 'CreatoDisplay', sans-serif;
      font-weight: 700;
      font-size: 180px;
      color: #2a2118;
      opacity: 0.15;
      line-height: 0.85;
      white-space: nowrap;
      pointer-events: none;
      letter-spacing: -5px;
    }
    @media (max-width: 991px) {
      .footer-watermark {
        font-size: 120px;
        bottom: -20px;
        letter-spacing: -3px;
      }
    }
    @media (max-width: 768px) {
      .footer-watermark {
        font-size: 80px;
        bottom: -14px;
        right: -5px;
        letter-spacing: -2px;
      }
    }

    /* Footer row layout — newsletter inline with menu */
    .footer-row-layout {
      flex-direction: column !important;
      gap: 40px;
    }
    .footer-top-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      width: 100%;
    }
    .footer-top-row .footer-list.v2 {
      display: flex;
      gap: 28px;
      flex-wrap: wrap;
    }
    .footer-legal-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      gap: 24px;
    }
    .footer-legal-row .footer-list.v1 {
      margin-top: 0;
    }
    .footer-legal-row .footer-copy-write-text {
      margin: 0;
      white-space: nowrap;
    }
    @media (max-width: 768px) {
      .footer { display: none !important; }
      .footer-top-row {
        flex-direction: column;
        align-items: flex-start;
        gap: 20px;
      }
      .footer-top-row .footer-list.v2 {
        display: flex !important;
        flex-wrap: wrap;
        gap: 10px 12px !important;
        justify-content: flex-start !important;
      }
      .footer-list.left.v1 {
        display: flex !important;
        flex-wrap: wrap;
        gap: 16px !important;
        justify-content: flex-start !important;
      }
      .footer-legal-row {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
      }
      .footer-copy-write-text {
        font-size: 12px !important;
        white-space: normal !important;
        opacity: 0.7;
      }
    }

    /* Logo marquee — infinite scroll */
    .logo-marquee {
      overflow: hidden;
      mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
      -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    }
    .logo-marquee-track {
      display: flex;
      gap: 64px;
      width: max-content;
      animation: marquee 20s linear infinite;
    }
    .logo-marquee-track .logo {
      flex: none;
      width: auto;
      height: 28px;
      max-width: none;
      max-height: none;
      opacity: 0.7;
      transition: opacity 0.3s ease;
    }
    .logo-marquee-track .logo:hover {
      opacity: 1;
    }
    @keyframes marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* Hero glow */
    .section.bnner .w-container > div:first-child {
      position: relative;
    }
    .section.bnner .w-container > div:first-child::after {
      content: '';
      position: absolute;
      top: 50%;
      left: 30%;
      transform: translate(-50%, -50%);
      width: 60%;
      height: 70%;
      background: radial-gradient(ellipse at center, rgba(255, 189, 89, 0.12) 0%, transparent 70%);
      pointer-events: none;
      z-index: 0;
      filter: blur(60px);
    }
    .section.bnner .animation-wrap {
      position: relative;
      z-index: 1;
    }
    [data-theme="dark"] .section.bnner .w-container > div:first-child::after {
      background: radial-gradient(ellipse at center, rgba(255, 189, 89, 0.18) 0%, transparent 70%);
      filter: blur(80px);
    }

    /* Hero slide-up animation (Webflow IX2 style) */
    .animation-wrap {
      overflow: hidden;
    }
    .animation-wrap h1 {
      transform: translate3d(0, 130%, 0) rotateZ(5deg);
      animation: slideUp 1s cubic-bezier(.23,1,.32,1) forwards;
    }
    .animation-wrap.v1 h1 {
      animation-delay: 0.15s;
    }
    @keyframes slideUp {
      to {
        transform: translate3d(0, 0, 0) rotateZ(0deg);
      }
    }

    /* Banner image parallax-zoom entrance */
    .banner-image-wrap img {
      transform: scale(1.15);
      animation: zoomIn 1.4s cubic-bezier(.23,1,.32,1) 0.3s forwards;
    }
    @keyframes zoomIn {
      to {
        transform: scale(1);
      }
    }

    /* Scroll-triggered fade-in (Webflow style) */
    .scroll-fade {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.4s cubic-bezier(.23,1,.32,1), transform 0.4s cubic-bezier(.23,1,.32,1);
    }
    .scroll-fade.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Staggered children */
    .scroll-fade-stagger > * {
      opacity: 0;
      transform: translateY(15px);
      transition: opacity 0.35s cubic-bezier(.23,1,.32,1), transform 0.35s cubic-bezier(.23,1,.32,1);
    }
    .scroll-fade-stagger.is-visible > * {
      opacity: 1;
      transform: translateY(0);
    }
    .scroll-fade-stagger.is-visible > *:nth-child(2) { transition-delay: 0.06s; }
    .scroll-fade-stagger.is-visible > *:nth-child(3) { transition-delay: 0.12s; }
    .scroll-fade-stagger.is-visible > *:nth-child(4) { transition-delay: 0.18s; }
    .scroll-fade-stagger.is-visible > *:nth-child(5) { transition-delay: 0.24s; }

    /* FAQ Section */
    .faq-section {
      background-color: #2a2118;
      border-radius: 24px;
      padding: 80px 60px;
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 60px;
    }
    .faq-left {
      position: sticky;
      top: 120px;
      align-self: start;
    }
    .faq-left h2 {
      font-family: var(--font-family);
      font-size: var(--_typography---heading--heading-h2);
      font-weight: var(--bold);
      color: var(--white);
      letter-spacing: var(--_typography---letter-spacing--letter-spacing-h2);
      line-height: var(--_typography---line-height--line-height-xs);
      margin: 0 0 24px 0;
    }
    .faq-left p {
      font-family: var(--font-family);
      font-size: var(--_typography---heading--heading-h4);
      color: rgba(255, 255, 255, 0.6);
      line-height: var(--_typography---line-height--line-height-l);
      margin: 0;
    }
    .faq-right {
      border-top: 1px solid rgba(255, 255, 255, 0.15);
    }
    .faq-item {
      border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    }
    .faq-question {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 24px 0;
      cursor: pointer;
      gap: 20px;
      transition: opacity 0.2s ease;
    }
    .faq-question:hover {
      opacity: 0.7;
    }
    .faq-question h4 {
      margin: 0;
      font-family: var(--font-family);
      font-size: var(--_typography---heading--heading-h4);
      font-weight: var(--medium);
      color: var(--white);
      letter-spacing: var(--_typography---letter-spacing--letter-spacing-h4);
      line-height: var(--_typography---line-height--line-height-m);
    }
    .faq-icon {
      width: 28px;
      height: 28px;
      min-width: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }
    .faq-icon::before,
    .faq-icon::after {
      content: '';
      position: absolute;
      background-color: var(--white);
      transition: transform 0.3s cubic-bezier(.23,1,.32,1);
    }
    .faq-icon::before {
      width: 20px;
      height: 1.5px;
    }
    .faq-icon::after {
      width: 1.5px;
      height: 20px;
    }
    .faq-item.is-open .faq-icon::before {
      transform: rotate(45deg);
    }
    .faq-item.is-open .faq-icon::after {
      transform: rotate(45deg);
    }
    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s cubic-bezier(.23,1,.32,1);
    }
    .faq-item.is-open .faq-answer {
      max-height: 500px;
    }
    .faq-answer-inner {
      padding: 0 0 24px 0;
    }
    .faq-answer-inner p {
      font-family: var(--font-family);
      font-size: var(--_typography---heading--paragraph);
      color: rgba(255, 255, 255, 0.6);
      line-height: var(--_typography---line-height--line-height-l);
      margin: 0;
    }
    .faq-answer-inner ul {
      list-style: none;
      padding: 12px 0 0 0;
      margin: 0;
    }
    .faq-answer-inner ul li {
      font-family: var(--font-family);
      font-size: var(--_typography---heading--paragraph);
      color: rgba(255, 255, 255, 0.6);
      line-height: var(--_typography---line-height--line-height-l);
      padding: 6px 0;
      padding-left: 20px;
      position: relative;
    }
    .faq-answer-inner ul li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 14px;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background-color: var(--primary);
    }
    @media (max-width: 768px) {
      .faq-section {
        grid-template-columns: 1fr;
        padding: 48px 28px;
        gap: 40px;
      }
      .faq-left {
        position: static;
      }
      .faq-left h2 {
        font-size: 36px;
      }
    }

    /* Service Accordion */
    .service-accordion-item {
      cursor: pointer;
    }
    .service-accordion-item .service-item-wrap {
      display: flex;
      align-items: center;
      text-decoration: none;
      color: inherit;
    }
    /* Override Webflow IX2 inline color — ensure readability in both modes */
    .service-title {
      color: var(--text-primary) !important;
      transition: color 0.4s ease !important;
    }
    .service-item-wrap:hover .service-title {
      color: var(--primary-tint) !important;
    }
    .service-accordion-item .service-icon-box {
      transition: transform 0.3s cubic-bezier(.23,1,.32,1);
    }
    .service-accordion-item.is-open .service-icon-box {
      transform: rotate(45deg);
    }
    .service-expand-content {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.5s cubic-bezier(.23,1,.32,1);
    }
    .service-accordion-item.is-open .service-expand-content {
      max-height: 400px;
    }
    .service-expand-inner {
      padding: 0 0 28px 0;
    }
    .service-expand-inner p {
      font-family: var(--font-family);
      font-size: var(--_typography---heading--paragraph);
      color: var(--text-primary);
      line-height: var(--_typography---line-height--line-height-l);
      margin: 0;
      opacity: 0.65;
    }
    .service-expand-inner ul {
      list-style: none;
      padding: 14px 0 0 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .service-expand-inner ul li {
      font-family: var(--font-family);
      font-size: 13px;
      font-weight: var(--medium);
      color: var(--text-primary);
      background: rgba(0,0,0,0.04);
      border: 1px solid rgba(0,0,0,0.08);
      border-radius: 100px;
      padding: 6px 16px;
      opacity: 0.7;
    }
    [data-theme="dark"] .service-expand-inner ul li {
      background: rgba(255,255,255,0.06);
      border-color: rgba(255,255,255,0.1);
    }

    /* Contact form rounded inputs */
    .contact-input {
      border-radius: 12px !important;
    }
    .contact-input.textarea {
      border-radius: 16px !important;
    }
    .contact-input::placeholder {
      color: #aaa !important;
      opacity: 1;
    }
    [data-theme="dark"] .contact-input::placeholder {
      color: #7a7268 !important;
    }

    /* Blog Carousel */
    .blog-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 32px;
    }
    .blog-header .blog-list {
      margin: 0;
      flex: 1;
    }
    /* Blog grid with expand */
    .blog-scroll-section {
      position: relative;
    }
    .blog-bottom-rows {
      display: flex;
      flex-direction: column;
      gap: 96px;
      margin-top: 192px;
    }
    .blog-trusted .blog-list {
      margin: 0 0 40px 0;
    }
    .models-marquee .logo-marquee-track {
      animation-direction: reverse;
    }
    .models-marquee .logo {
      max-width: 195px;
    }
    .blog-carousel-track {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .blog-carousel-track .blog-slide {
      display: block;
    }
    .blog-carousel-track .blog-slide.blog-hidden {
      display: none;
    }
    .blog-carousel-track .blog-slide .blog-link-block {
      display: block;
    }
    .blog-carousel-track .blog-slide .project-image-wrap {
      border-radius: 16px;
      overflow: hidden;
      aspect-ratio: 16 / 10;
    }
    .blog-carousel-track .blog-slide .blog-main-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .blog-carousel-track .blog-slide .project-title.v1 {
      font-size: 20px;
    }
    .blog-expand-wrap {
      display: flex;
      justify-content: center;
      margin-top: 48px;
    }
    .blog-expand-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 16px 40px;
      border: 2px solid var(--primary);
      border-radius: 100px;
      background: transparent;
      color: var(--primary);
      font-family: var(--font-family);
      font-size: 16px;
      font-weight: var(--semibold, 600);
      cursor: pointer;
      transition: background 0.3s, color 0.3s, transform 0.2s;
      letter-spacing: 0.5px;
    }
    .blog-expand-btn:hover {
      background: var(--primary);
      color: #fff;
      transform: scale(1.03);
    }
    .blog-expand-btn .expand-arrow {
      transition: transform 0.3s;
      font-size: 20px;
    }
    .blog-expand-btn.is-expanded .expand-arrow {
      transform: rotate(180deg);
    }
    @media (max-width: 991px) {
      .blog-carousel-track {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (max-width: 768px) {
      .blog-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
      }
      .blog-carousel-track {
        grid-template-columns: 1fr;
      }
    }

    /* Banner subtitle fade-in */
    .list.banner {
      opacity: 0;
      transform: translateY(20px);
      animation: fadeInUp 0.8s cubic-bezier(.23,1,.32,1) 0.5s forwards;
    }
    @keyframes fadeInUp {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* ===== DARK MODE — inline overrides ===== */
    /* Smooth transitions */
    body, .section, .navbar, .navbar-no-shadow-container,
    .pricing-wrap, .pricing-inner-wrap,
    .testimonial-slider-content-wrapper,
    .contact-input, .service-line {
      transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
    }

    /* Theme toggle button */
    .theme-toggle { display: none !important; }
    .theme-toggle-hidden {
      background: none;
      border: 1.5px solid var(--border-color, #ececec);
      border-radius: 50%;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: var(--text-primary);
      transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
      flex-shrink: 0;
      margin-right: 12px;
    }
    .theme-toggle:hover {
      background-color: var(--shape);
    }
    .theme-icon.moon { display: none; }
    .theme-icon.sun { display: block; }
    [data-theme="dark"] .theme-icon.moon { display: block; }
    [data-theme="dark"] .theme-icon.sun { display: none; }

    /* Navbar background in dark mode */
    [data-theme="dark"] .navbar-no-shadow-container {
      background-color: var(--bg-body);
    }
    [data-theme="dark"] .navbar {
      background: rgba(9, 8, 14, 0.85);
    }

    /* Logo inversion */
    [data-theme="dark"] .navbar-brand .image {
      filter: invert(1);
    }

    /* Blog post titles (hardcoded inline style="color:rgb(9,8,14)") */
    [data-theme="dark"] .project-title.v1 {
      color: var(--text-primary) !important;
    }

    /* Blog short text */
    [data-theme="dark"] .blog-short-text {
      color: var(--gray-color);
    }

    /* FAQ section — scoped override, keeps white text on dark bg */
    [data-theme="dark"] .faq-section {
      background-color: #241e17 !important;
      --white: white;
    }

    /* CTA button — stays amber with dark text in both modes */
    [data-theme="dark"] .primary-btn-wrap .button-text {
      color: #09080e !important;
    }
    [data-theme="dark"] .primary-btn-wrap .arrow-01 {
      filter: brightness(0) !important;
    }

    /* Logo marquee inversion */
    [data-theme="dark"] .logo-marquee-track .logo {
      filter: invert(1) brightness(1.5);
      opacity: 0.5;
    }
    [data-theme="dark"] .logo-marquee-track .logo:hover {
      opacity: 0.8;
    }

    /* Service accordion icons */
    [data-theme="dark"] .sevice-icon {
      filter: brightness(0) invert(1);
    }

    /* Service expand content */
    [data-theme="dark"] .service-expand-inner p {
      color: var(--text-primary);
    }

    /* Images subtle brightness reduction */
    [data-theme="dark"] .project-image-wrap img,
    [data-theme="dark"] .banner-image-wrap img {
      filter: brightness(0.88);
    }

    /* Banner subtitle */
    [data-theme="dark"] .banner-subtittle {
      color: var(--gray-color);
    }

    /* About section stats */
    [data-theme="dark"] .about-number-title {
      color: var(--text-primary);
    }

    /* Read time text */
    [data-theme="dark"] .read-time {
      color: var(--gray-color);
    }


    /* Pricing text */
    [data-theme="dark"] .pricing-text {
      color: var(--gray-color);
    }
    [data-theme="dark"] .tick-text {
      color: var(--text-primary);
    }

    .pricing-name {
      text-align: left;
      padding-left: 34px;
    }

    /* Service founder portrait + speech bubble */
    .service-left-block {
      display: flex;
      flex-direction: column;
      height: 100%;
      position: sticky;
      top: 100px;
      align-self: start;
      justify-content: flex-start !important;
    }
    .service-founder {
      margin-top: 0;
      position: relative;
    }
    .founder-slides {
      position: relative;
      width: 100%;
    }
    .founder-slide {
      opacity: 0;
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      transition: opacity 0.5s ease;
      pointer-events: none;
    }
