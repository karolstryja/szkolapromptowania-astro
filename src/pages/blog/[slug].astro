---
import { getCollection } from 'astro:content';
import { marked } from 'marked';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;

let md = post.body || '';
var heroSrc = (post.data.image || '').replace(/^\//, '');
var isHeroVideo = heroSrc.match(/\.(mp4|webm|mov)$/i);

md = md.replace(/:::video\n([\s\S]*?):::/g, function(match, content) {
    var src = content.trim().replace(/^\//, '');
    if (isHeroVideo && src === heroSrc) return '';
    return '<div class="blog-video"><video src="/' + src + '" controls playsinline preload="metadata"></video></div>';
});

md = md.replace(/:::gallery-(masonry|grid|fullwidth|slider)\n([\s\S]*?):::/g, function(match, layout, content) {
    var lines = content.trim().split('\n');
    var count = lines.length;
    var figures = lines.map(function(line) {
        var pts = line.split('|');
        var src = pts[0].trim().replace(/^\//, '');
        var caption = pts[1] ? pts[1].trim() : '';
        return '<figure><img src="/' + src + '" alt="' + caption + '" loading="lazy"></figure>';
    }).join('\n');
    return '<div class="blog-gallery gallery-' + layout + '" data-count="' + count + '">' + figures + '</div>';
});

const htmlContent = marked.parse(md);

const title = post.data.title + ' — Szkoła Promptowania';
const tags = post.data.tags || [];

// determine hero media
const videoSrc = post.data.video ? '/' + post.data.video.replace(/^\//, '') : '';
const imgSrc = post.data.image ? '/' + post.data.image.replace(/^\//, '') : '';
const showVideo = !!videoSrc || !!(imgSrc && isHeroVideo);
const finalVideoSrc = videoSrc || (isHeroVideo ? imgSrc : '');
const showImage = !!imgSrc && !isHeroVideo && !videoSrc;
---
<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="utf-8">
  <title>{title}</title>
  <meta content="width=device-width, initial-scale=1" name="viewport">
  <link href="/css/normalize.css" rel="stylesheet">
  <link href="/css/webflow.css" rel="stylesheet">
  <link href="/css/karols-stunning-site-350399.webflow.css" rel="stylesheet">
  <link href="/images/favicon.svg" rel="shortcut icon" type="image/x-icon">
  <link href="/images/webclip.svg" rel="apple-touch-icon">
  <script>
    /* Theme always matches landing page (light) — no dark mode auto-detect */
    (function(){
      document.documentElement.removeAttribute('data-theme');
    })();
  </script>
  <style>
    /* ═══════════════════════════════════════════
       BLOG — refined typography
       ═══════════════════════════════════════════ */

    /* Fix Webflow overflow:hidden breaking IntersectionObserver */
    .page-wrapper { overflow: clip; }

    /* ── Hero ── */
    .blog-hero-wrapper {
      width: 100%;
      overflow: hidden;
    }
    .blog-hero-image {
      width: 100%;
      height: 520px;
      object-fit: cover;
      display: block;
    }
    .blog-hero-video {
      width: 100%;
      height: 720px;
      object-fit: cover;
      display: block;
      background: #000;
    }

    /* ── Narrow article container ── */
    .blog-article {
      max-width: 720px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* ── Top bar: back + tags ── */
    .blog-top-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 24px;
      font-family: var(--font-family);
    }
    .blog-back-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 14px;
      font-weight: 500;
      color: var(--gray-color);
      text-decoration: none;
      transition: color 0.2s;
    }
    .blog-back-link:hover { color: var(--primary); }
    .blog-meta-tags {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }
    .blog-meta-tag {
      background: rgba(255,189,89,0.15);
      color: var(--primary);
      padding: 4px 12px;
      border-radius: 100px;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    /* ── Title ── */
    .blog-article-title {
      font-family: var(--font-family);
      font-size: 64px !important;
      font-weight: 700 !important;
      line-height: 1.1 !important;
      letter-spacing: -2px !important;
      color: var(--text-primary);
      margin: 0 0 48px 0;
    }

    /* ── Article body ── */
    .blog-article-body {
      font-family: var(--font-family);
      font-size: 16px !important;
      line-height: 1.65;
      color: #1a1a1a;
    }

    .blog-article-body :global(h2) {
      font-size: 24px !important;
      font-weight: 700 !important;
      line-height: 1.3 !important;
      letter-spacing: -0.5px !important;
      color: var(--text-primary);
      margin: 48px 0 16px 0;
    }
    .blog-article-body :global(h3) {
      font-size: 20px !important;
      font-weight: 700 !important;
      line-height: 1.3 !important;
      letter-spacing: -0.3px !important;
      margin: 32px 0 12px 0;
      color: var(--text-primary);
    }

    /* ── Paragraphs ── */
    .blog-article-body p {
      margin: 0 0 24px 0;
    }
    .blog-article-body strong {
      font-weight: 700;
    }

    /* ── Blockquote ── */
    .blog-article-body :global(blockquote) {
      margin: 32px 0;
      padding: 8px 0 8px 20px;
      border-left: 2px solid var(--primary);
      font-size: 16px !important;
      font-style: italic;
      line-height: 1.6;
      color: #555;
    }
    .blog-article-body :global(blockquote p) { margin: 0; }

    /* ── Lists ── */
    .blog-article-body ul,
    .blog-article-body ol {
      margin: 20px 0 28px 0;
      padding-left: 20px;
    }
    .blog-article-body li {
      margin-bottom: 12px;
    }

    /* ── Code ── */
    .blog-article-body code {
      background: #f4f1ea;
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 15px;
      font-family: monospace;
    }
    .blog-article-body pre {
      background: #1a1611;
      color: #f5f0eb;
      padding: 24px;
      border-radius: 12px;
      overflow-x: auto;
      margin: 32px 0;
      font-size: 14px;
      line-height: 1.6;
    }
    .blog-article-body pre code {
      background: none;
      padding: 0;
      color: inherit;
      font-size: inherit;
    }

    /* ── HR ── */
    .blog-article-body hr {
      border: none;
      height: 1px;
      background: #eee;
      margin: 56px 0;
    }

    /* ── Galleries & Video ── */
    .blog-gallery, .blog-video {
      width: calc(100% + 200px);
      margin-left: -100px;
      margin-top: 48px;
      margin-bottom: 48px;
    }

    .gallery-masonry {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }
    .gallery-masonry figure { margin: 0; }
    .gallery-masonry img { width: 100%; height: 300px; object-fit: cover; border-radius: 8px; }

    @media (max-width: 991px) {
      .blog-gallery, .blog-video {
        width: 100%;
        margin-left: 0;
      }
      .gallery-masonry { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
      .blog-meta-tags {
        display: none !important;
      }
      :global(.footer) {
        display: none !important;
      }
    }

    /* ── Animations ── */
    .blog-article-body > * {
      opacity: 0;
      transform: translateY(15px);
      transition: all 0.5s ease-out;
    }
    .blog-article-body > .is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
</head>
<body>
  <div class="page-wrapper">
    <Navbar />

    <!-- Hero -->
    <div class="blog-hero-wrapper" style="margin-top: 0px;">
      {showImage && <img class="blog-hero-image" src={imgSrc} alt={post.data.title} />}
      {showVideo && <video class="blog-hero-video" src={finalVideoSrc} poster={videoSrc ? imgSrc : ""} controls playsinline preload="metadata"></video>}
    </div>

    <!-- Article -->
    <section class="section" style="padding-top: 64px;">
      <div class="blog-article">
        <div class="blog-top-bar">
          <a href="/#Blog" class="blog-back-link">← powrót do bloga</a>
          <div class="blog-meta-tags">{tags.map(t => <span class="blog-meta-tag">{t}</span>)}</div>
        </div>
        <h1 class="blog-article-title">{post.data.title}</h1>
        <div class="blog-article-body" set:html={htmlContent}></div>
      </div>
    </section>

    <Footer />
  </div>

  <script src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=698de4b991fcd3d8eb65a6e5" type="text/javascript" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
  <script is:inline src="/js/webflow.js" type="text/javascript"></script>

  <script>
    // Scroll animations
    function initScrollAnimations() {
      var els = document.querySelectorAll('.blog-article-body > *');
      if (!els.length) return;
      if ('IntersectionObserver' in window) {
        var obs = new IntersectionObserver(function(entries) {
          entries.forEach(function(e) {
            if (e.isIntersecting) { 
              e.target.classList.add('is-visible'); 
              obs.unobserve(e.target); 
            }
          });
        }, { threshold: 0.1 });
        els.forEach(function(el) { obs.observe(el); });
      } else {
        els.forEach(function(el) { el.classList.add('is-visible'); });
      }
    }
    initScrollAnimations();
  </script>
</body>
</html>
