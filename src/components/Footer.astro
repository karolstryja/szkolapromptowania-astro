---
<style>
    /* Footer decorative watermark — mimics original Slayed positioning */
    .footer {
      background-color: #09080e !important; /* Force dark background at top level */
    }
    .footer-inner-wrap {
      overflow: hidden !important;
      position: relative;
      background-color: #09080e !important;
      padding: 80px 0;
      color: white;
    }
    .footer-watermark {
      position: absolute;
      bottom: -30px;
      right: -10px;
      font-family: 'CreatoDisplay', 'Inter', sans-serif;
      font-weight: 700;
      font-size: 180px;
      color: rgba(255, 255, 255, 0.05) !important;
      line-height: 0.85;
      white-space: nowrap;
      pointer-events: none;
      letter-spacing: -5px;
      z-index: 0;
      display: block !important;
      text-transform: lowercase;
    }
    
    .footer-row-layout {
      flex-direction: column !important;
      gap: 40px;
    }
    .footer-top-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      width: 100%;
      position: relative;
      z-index: 1;
    }
    .footer-top-row .footer-list.v2 {
      display: flex;
      gap: 28px;
      flex-wrap: wrap;
    }
    .footer-link {
      color: rgba(255,255,255,0.7) !important;
      transition: color 0.3s ease;
      text-decoration: none;
    }
    .footer-link:hover {
      color: var(--primary) !important;
    }

    .footer-legal-row {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      width: 100%;
      gap: 24px;
      position: relative;
      z-index: 1;
      border-top: 1px solid rgba(255,255,255,0.1);
      padding-top: 40px;
    }
    .footer-copy-write-text {
      margin: 0;
      white-space: nowrap;
      color: rgba(255,255,255,0.4) !important;
      font-size: 13px;
    }

    .footer-address-block {
      font-size: 14px;
      line-height: 1.6;
      color: #ffffff !important;
      text-align: right;
      margin-bottom: 12px;
      font-weight: 400;
      opacity: 1 !important;
      display: block !important;
    }

    .mobile-yellow-tile {
      display: none;
    }

    @media (max-width: 768px) {
      .footer-inner-wrap {
        padding: 60px 0;
      }
      .footer-top-row, .footer-address-block {
        display: none !important;
      }
      .mobile-yellow-tile {
        display: block !important;
        background-color: var(--primary) !important;
        padding: 32px 24px !important;
        border-radius: 24px !important;
        margin-bottom: 48px !important;
        color: #09080e !important;
        position: relative;
        z-index: 2;
        width: 100%;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
      }
      .mobile-yellow-tile .address-text {
        font-size: 17px !important;
        line-height: 1.4 !important;
        font-weight: 700 !important;
        margin-bottom: 24px !important;
        color: #09080e !important;
      }
      .mobile-yellow-tile .footer-list.left.v1 {
        display: flex !important;
        flex-direction: row !important;
        margin: 0 !important;
        padding: 0 !important;
        gap: 20px !important;
      }
      .mobile-yellow-tile .social-image {
        filter: brightness(0) !important;
        width: 24px;
        height: 24px;
      }
      .footer-legal-row {
        flex-direction: column;
        align-items: flex-start;
        border-top: none;
        padding-top: 0;
      }
      .footer-copy-write-text {
        text-align: left;
        white-space: normal;
        margin-top: 8px;
        display: block !important;
      }
      .mobile-only-name span {
        color: rgba(255,255,255,0.4) !important;
      }
    }

    /* Dark mode override — keep it dark */
    [data-theme="dark"] .footer,
    [data-theme="dark"] .footer-inner-wrap {
      background-color: #050507 !important;
    }
</style>

<div class="footer">
  <section class="footer-inner-wrap">
    <div class="footer-watermark">szkoła promptowania</div>
    <div class="w-layout-blockcontainer container v1 w-container">
      <div class="footer-form-wrap footer-row-layout">
        
        <!-- Desktop Top Row: Menu & Socials -->
        <div class="footer-top-row">
          <ul role="list" class="footer-list v2">
            <li class="footer-list-item"><a href="/#Home" class="footer-link">start</a></li>
            <li class="footer-list-item"><a href="/#about" class="footer-link">o nas</a></li>
            <li class="footer-list-item"><a href="/#Service" class="footer-link">warsztaty</a></li>
            <li class="footer-list-item"><a href="/#Project" class="footer-link">efekty</a></li>
            <li class="footer-list-item"><a href="/#Pricing" class="footer-link">cennik</a></li>
            <li class="footer-list-item"><a href="/#Blog" class="footer-link">blog</a></li>
            <li class="footer-list-item"><a href="/#FAQ" class="footer-link">faq</a></li>
            <li class="footer-list-item"><a href="/#Contact" class="footer-link">kontakt</a></li>
          </ul>
          <!-- Desktop Socials - White icons -->
          <ul role="list" class="footer-list left v1">
            <li class="footer-list-item"><a href="#" class="social-link-block w-inline-block"><img src="/images/Social-Icons.svg" loading="lazy" alt="X / Twitter" class="social-image" style="filter: invert(1) brightness(2);"></a></li>
            <li class="footer-list-item"><a href="#" class="social-link-block w-inline-block"><img src="/images/fi_20837.svg" loading="lazy" alt="Facebook" class="social-image" style="filter: invert(1) brightness(2);"></a></li>
            <li class="footer-list-item"><a href="#" class="social-link-block w-inline-block"><img src="/images/Social-Icons-1.svg" loading="lazy" alt="Instagram" class="social-image" style="filter: invert(1) brightness(2);"></a></li>
            <li class="footer-list-item"><a href="#" class="social-link-block w-inline-block"><img src="/images/fi_2111532.svg" loading="lazy" alt="LinkedIn" class="social-image" style="filter: invert(1) brightness(2);"></a></li>
          </ul>
        </div>

        <!-- Mobile Yellow Tile (The "Card") -->
        <div class="mobile-yellow-tile">
          <div class="address-text">
            Archetype Plus Sp. z o.o.<br/>
            Plac Małachowskiego 2<br/>
            00-066 Warszawa
          </div>
          <ul role="list" class="footer-list left v1">
            <li class="footer-list-item"><a href="#" class="social-link-block w-inline-block"><img src="/images/Social-Icons.svg" loading="lazy" alt="X / Twitter" class="social-image"></a></li>
            <li class="footer-list-item"><a href="#" class="social-link-block w-inline-block"><img src="/images/fi_20837.svg" loading="lazy" alt="Facebook" class="social-image"></a></li>
            <li class="footer-list-item"><a href="#" class="social-link-block w-inline-block"><img src="/images/Social-Icons-1.svg" loading="lazy" alt="Instagram" class="social-image"></a></li>
            <li class="footer-list-item"><a href="#" class="social-link-block w-inline-block"><img src="/images/fi_2111532.svg" loading="lazy" alt="LinkedIn" class="social-image"></a></li>
          </ul>
        </div>

        <!-- Bottom Row: Legal + Right-aligned Address -->
        <div class="footer-legal-row">
          <ul role="list" class="footer-list v1">
            <li class="footer-list-item"><a href="/polityka-prywatnosci" class="footer-link">polityka prywatności</a></li>
            <li class="footer-list-item mobile-only-name" style="display:none;"><span class="footer-link">szkoła promptowania</span></li>
          </ul>
          
          <div style="display: flex; flex-direction: column; align-items: flex-end;">
            <div class="footer-address-block">
              Archetype Plus Sp. z o.o.<br/>
              Plac Małachowskiego 2<br/>
              00-066 Warszawa
            </div>
            <p class="footer-copy-write-text">© 2026 Szkoła Promptowania. Wszelkie prawa zastrzeżone.</p>
          </div>
        </div>

      </div>
    </div>
  </section>
</div>
