<style>
    /* Footer decorative watermark — mimics original Slayed positioning */
    .footer {
      background-color: #ffbd59 !important;
    }
    .footer-inner-wrap {
      overflow: hidden !important;
      position: relative;
      background-color: #ffbd59 !important;
      padding: 80px 0;
      color: white;
    }
    .footer-watermark {
      position: absolute;
      bottom: -30px;
      right: -10px;
      font-family: 'CreatoDisplay', 'Inter', sans-serif;
      font-weight: 700;
      font-size: 180px;
      color: rgba(255, 255, 255, 0.15) !important;
      line-height: 0.85;
      white-space: nowrap;
      pointer-events: none;
      letter-spacing: -5px;
      z-index: 0;
      display: block !important;
      text-transform: lowercase;
    }
    
    .footer-row-layout {
      flex-direction: column !important;
      gap: 40px;
    }
    .footer-top-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      width: 100%;
      position: relative;
      z-index: 1;
    }
    .footer-top-row .footer-list.v2 {
      display: flex;
      gap: 28px;
      flex-wrap: wrap;
    }
    .footer-link {
      color: #ffffff !important;
      transition: color 0.3s ease;
      text-decoration: none;
    }
    .footer-link:hover {
      color: rgba(255,255,255,0.6) !important;
    }

    .footer-legal-row {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      width: 100%;
      gap: 24px;
      position: relative;
      z-index: 1;
      border-top: 1px solid rgba(255,255,255,0.3);
      padding-top: 40px;
    }
    .footer-copy-write-text {
      margin: 0;
      white-space: nowrap;
      color: rgba(255,255,255,0.7) !important;
      font-size: 13px;
    }

    .footer-address-block {
      font-size: 14px;
      line-height: 1.6;
      color: #ffffff !important;
      text-align: right;
      margin-bottom: 12px;
      font-weight: 400;
      opacity: 1 !important;
      display: block !important;
    }

    .mobile-yellow-tile {
      display: none;
    }

    .footer-address-mobile {
      display: none;
    }

    @media (max-width: 768px) {
      .footer-inner-wrap {
        padding: 32px 0;
      }
      .footer-top-row, .footer-address-block,
      .footer-copy-write-text {
        display: none !important;
      }
      .footer-row-layout {
        gap: 0 !important;
        margin-top: 0 !important;
      }
      /* Ikony po lewej, minimalna przestrzeń nad nimi */
      .mobile-yellow-tile {
        display: flex !important;
        flex-direction: row !important;
        justify-content: flex-start !important;
        align-items: center !important;
        background: none !important;
        padding: 0 !important;
        border-radius: 0 !important;
        margin-bottom: 16px !important;
        box-shadow: none !important;
        width: 100%;
        position: relative;
        z-index: 2;
      }
      .mobile-yellow-tile .footer-list.left.v1 {
        display: flex !important;
        flex-direction: row !important;
        justify-content: flex-start !important;
        margin: 0 !important;
        padding: 0 !important;
        gap: 18px !important;
      }
      .mobile-yellow-tile .social-image {
        filter: brightness(0) invert(1) !important;
        width: 20px;
        height: 20px;
      }
      /* Dolny rząd: polityka (lewo) | adres (prawo) */
      .footer-legal-row {
        flex-direction: row !important;
        align-items: flex-end !important;
        justify-content: space-between !important;
        border-top: none !important;
        padding-top: 0 !important;
        margin-top: 0 !important;
        gap: 16px;
      }
      .footer-legal-row > ul {
        margin: 0 !important;
        padding: 0 !important;
      }
      .footer-legal-row .footer-link {
        font-size: 13px !important;
        font-weight: 400 !important;
        color: rgba(255,255,255,0.75) !important;
        white-space: nowrap;
        line-height: 1.4;
      }
      .footer-address-mobile {
        display: block !important;
        font-size: 13px !important;
        font-weight: 400 !important;
        color: rgba(255,255,255,0.75) !important;
        text-align: right;
        line-height: 1.4;
      }
      .mobile-yellow-tile .social-image {
        filter: brightness(0) invert(1) !important;
        width: 24px !important;
        height: 24px !important;
      }
    }

    /* Desktop social icons — white */
    @media (min-width: 769px) {
      .footer-top-row .social-image {
        filter: brightness(0) invert(1) !important;
      }
    }

    /* Dark mode override — keep yellow on desktop */
    [data-theme="dark"] .footer,
    [data-theme="dark"] .footer-inner-wrap {
      background-color: #ffbd59 !important;
    }
</style>

<div class="footer">
  <section class="footer-inner-wrap">
    <div class="footer-watermark">szkoła promptowania</div>
    <div class="w-layout-blockcontainer container v1 w-container">
      <div class="footer-form-wrap footer-row-layout">
        
        <!-- Desktop Top Row: Menu & Socials -->
        <div class="footer-top-row">
          <ul role="list" class="footer-list v2">
            <li class="footer-list-item"><a href="/#Home" class="footer-link">start</a></li>
            <li class="footer-list-item"><a href="/#about" class="footer-link">o nas</a></li>
            <li class="footer-list-item"><a href="/#Service" class="footer-link">warsztaty</a></li>
            <li class="footer-list-item"><a href="/#Project" class="footer-link">efekty</a></li>
            <li class="footer-list-item"><a href="/#Pricing" class="footer-link">cennik</a></li>
            <li class="footer-list-item"><a href="/#Blog" class="footer-link">blog</a></li>
            <li class="footer-list-item"><a href="/#FAQ" class="footer-link">faq</a></li>
            <li class="footer-list-item"><a href="/#Contact" class="footer-link">kontakt</a></li>
          </ul>
          <!-- Desktop Socials - White icons -->
          <ul role="list" class="footer-list left v1">
            <li class="footer-list-item"><a href="https://www.linkedin.com" class="social-link-block w-inline-block"><img src="/images/icon-linkedin.svg" loading="lazy" alt="LinkedIn" class="social-image" style="filter: invert(1) brightness(2);"></a></li>
            <li class="footer-list-item"><a href="https://99twarzyAI.pl" class="social-link-block w-inline-block"><img src="/images/icon-podcast.svg" loading="lazy" alt="Podcast 99 twarzy AI" class="social-image" style="filter: invert(1) brightness(2);"></a></li>
            <li class="footer-list-item"><a href="https://rewolucjaai.com" class="social-link-block w-inline-block"><img src="/images/icon-blog.svg" loading="lazy" alt="Blog Rewolucja AI" class="social-image" style="filter: invert(1) brightness(2);"></a></li>
          </ul>
        </div>

        <!-- Mobile icons row -->
        <div class="mobile-yellow-tile">
          <ul role="list" class="footer-list left v1">
            <li class="footer-list-item"><a href="https://www.linkedin.com" class="social-link-block w-inline-block"><img src="/images/icon-linkedin.svg" loading="lazy" alt="LinkedIn" class="social-image"></a></li>
            <li class="footer-list-item"><a href="https://99twarzyAI.pl" class="social-link-block w-inline-block"><img src="/images/icon-podcast.svg" loading="lazy" alt="Podcast 99 twarzy AI" class="social-image"></a></li>
            <li class="footer-list-item"><a href="https://rewolucjaai.com" class="social-link-block w-inline-block"><img src="/images/icon-blog.svg" loading="lazy" alt="Blog Rewolucja AI" class="social-image"></a></li>
          </ul>
        </div>

        <!-- Bottom Row: Legal + Right-aligned Address -->
        <div class="footer-legal-row">
          <ul role="list" class="footer-list v1">
            <li class="footer-list-item"><a href="/polityka-prywatnosci" class="footer-link">polityka prywatności</a></li>
            <li class="footer-list-item mobile-only-name" style="display:none;"><span class="footer-link">szkoła promptowania</span></li>
          </ul>
          
          <div style="display: flex; flex-direction: column; align-items: flex-end;">
            <div class="footer-address-block">
              Archetype Plus Sp. z o.o.<br/>
              Plac Małachowskiego 2<br/>
              00-066 Warszawa
            </div>
            <span class="footer-address-mobile">Archetype Plus Sp. z o.o.<br/>Plac Małachowskiego 2, 00-066 Warszawa</span>
            <p class="footer-copy-write-text"><span class="copyright-short">© 2026</span><span class="copyright-long"> Szkoła Promptowania. Wszelkie prawa zastrzeżone.</span></p>
          </div>
        </div>

      </div>
    </div>
  </section>
</div>
