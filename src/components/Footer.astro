---
---
<style>
    /* Footer decorative watermark — mimics original Slayed positioning */
    .footer-inner-wrap {
      overflow: hidden !important;
      position: relative;
    }
    .footer-watermark {
      position: absolute;
      bottom: -30px;
      right: -10px;
      font-family: 'CreatoDisplay', sans-serif;
      font-weight: 700;
      font-size: 180px;
      color: #2a2118;
      opacity: 0.15;
      line-height: 0.85;
      white-space: nowrap;
      pointer-events: none;
      letter-spacing: -5px;
      z-index: 0;
    }
    @media (max-width: 991px) {
      .footer-watermark {
        font-size: 120px;
        bottom: -20px;
        letter-spacing: -3px;
      }
    }
    @media (max-width: 768px) {
      .footer-watermark {
        font-size: 80px;
        bottom: -14px;
        right: -5px;
        letter-spacing: -2px;
      }
    }

    /* Footer row layout — newsletter inline with menu */
    .footer-row-layout {
      flex-direction: column !important;
      gap: 40px;
    }
    .footer-top-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      width: 100%;
      position: relative;
      z-index: 1;
    }
    .footer-top-row .footer-list.v2 {
      display: flex;
      gap: 28px;
      flex-wrap: wrap;
    }
    .footer-legal-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      gap: 24px;
      position: relative;
      z-index: 1;
    }
    .footer-legal-row .footer-list.v1 {
      margin-top: 0;
    }
    .footer-legal-row .footer-copy-write-text {
      margin: 0;
      white-space: nowrap;
    }
    @media (max-width: 768px) {
      .footer-top-row {
        flex-direction: column;
        align-items: flex-start;
        gap: 20px;
      }
      .footer-top-row .footer-list.v2 {
        display: flex !important;
        flex-wrap: wrap;
        gap: 10px 12px !important;
        justify-content: flex-start !important;
      }
      .footer-list.left.v1 {
        display: flex !important;
        flex-wrap: wrap;
        gap: 16px !important;
        justify-content: flex-start !important;
      }
      .footer-legal-row {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
      }
      .footer-copy-write-text {
        font-size: 12px !important;
        white-space: normal !important;
        opacity: 0.7;
      }
    }
    
    /* Dark mode footer watermark */
    [data-theme="dark"] .footer-watermark {
      color: #2a2118;
      opacity: 0.15;
    }
</style>
<div class="footer">
  <section class="footer-inner-wrap">
    <div class="footer-watermark">szkoła promptowania</div>
    <div class="w-layout-blockcontainer container v1 w-container">
      <div class="footer-form-wrap footer-row-layout">
        <!-- Row 1: menu links -->
        <div class="footer-top-row">
          <ul role="list" class="footer-list v2">
            <li class="footer-list-item"><a href="/#Home" class="footer-link">start</a></li>
            <li class="footer-list-item"><a href="/#about" class="footer-link">o nas</a></li>
            <li class="footer-list-item"><a href="/#Service" class="footer-link">warsztaty</a></li>
            <li class="footer-list-item"><a href="/#Project" class="footer-link">efekty</a></li>
            <li class="footer-list-item"><a href="/#Pricing" class="footer-link">cennik</a></li>
            <li class="footer-list-item"><a href="/#Blog" class="footer-link">blog</a></li>
            <li class="footer-list-item"><a href="/#FAQ" class="footer-link">faq</a></li>
            <li class="footer-list-item"><a href="/#Contact" class="footer-link">kontakt</a></li>
          </ul>
        </div>
        <!-- Row 2: social icons -->
        <ul role="list" class="footer-list left v1">
          <li class="footer-list-item"><a href="#" class="social-link-block w-inline-block"><img src="/images/Social-Icons.svg" loading="lazy" alt="X / Twitter" class="social-image"></a></li>
          <li class="footer-list-item"><a href="#" class="social-link-block w-inline-block"><img src="/images/fi_20837.svg" loading="lazy" alt="Facebook" class="social-image"></a></li>
          <li class="footer-list-item"><a href="#" class="social-link-block w-inline-block"><img src="/images/Social-Icons-1.svg" loading="lazy" alt="Instagram" class="social-image"></a></li>
          <li class="footer-list-item"><a href="#" class="social-link-block w-inline-block"><img src="/images/fi_2111532.svg" loading="lazy" alt="LinkedIn" class="social-image"></a></li>
        </ul>
        <!-- Row 3: legal + copyright -->
        <div class="footer-legal-row">
          <ul role="list" class="footer-list v1">
            <li class="footer-list-item"><a href="/polityka-prywatnosci" class="footer-link">polityka prywatności</a></li>
          </ul>
          <p class="footer-copy-write-text">© 2026 Szkoła Promptowania. Wszelkie prawa zastrzeżone.</p>
        </div>
      </div>
    </div>
  </section>
</div>
